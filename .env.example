# Required for data generation and evaluation (uses Anthropic Batch API).
ANTHROPIC_API_KEY=

# Optional: comma-separated names that the decontamination pass scrubs from
# training data and evaluation output. Leave empty to disable.
# Example: CREATOR_NAMES=Jane Doe,John Smith
CREATOR_NAMES=

# Optional: override the detected project root. Set this if you move the
# package out of its repository checkout.
# NEO_LOGOS_ROOT=

# Optional: author metadata used by paper_reviewer/write_final_paper scripts.
# PAPER_AUTHOR=
# PAPER_AFFILIATION=
